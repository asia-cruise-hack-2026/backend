# Google Maps Platform — JavaScript API (브라우저 노출됨)
# 콘솔에서 반드시 제한을 걸 것: HTTP 리퍼러 + Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=여기에_발급받은_키

# 비짓제주 공개 API — 데이터 재수집(scripts/)에만 사용
VISITJEJU_API_KEY=여기에_발급받은_키

# ---- Cloud SQL (PostgreSQL) ----
# 로컬 개발: 공개 IP로 TCP 접속 (인스턴스의 승인된 네트워크에 본인 IP 등록 필요)
DB_HOST=인스턴스_공개_IP
DB_PORT=5432
DB_NAME=tamrapass
DB_USER=postgres
DB_PASSWORD=여기에_비밀번호

# Cloud Run 배포 시에만 사용 — 있으면 유닉스 소켓으로 접속합니다
# INSTANCE_CONNECTION_NAME=프로젝트:리전:인스턴스
